#!/bin/bash
#SBATCH --job-name=11_mapdamage_vitis_vinifera
#SBATCH --ntasks=1
#SBATCH -p smp
#SBATCH --mem=50G
#SBATCH --mail-user=alexa.martin@inrae.fr
#SBATCH --mail-type=ALL
#SBATCH --error="/home/amartin3/CapoSagro_Alexa/00_scripts/11_mapdamage_vitis_vinifera.err"
#SBATCH --output="/home/amartin3/CapoSagro_Alexa/00_scripts/11_mapdamage_vitis_vinifera.out"


BASE_DIR="/home/amartin3/12_mapdamage_murinae/sed6/Vitis_vinifera"
REF_FASTA="/home/amartin3/genomes/Vitis_vinifera.fna" # Modifie si le chemin de ta réf vigne est différent
OUT_DIR="${BASE_DIR}/combined_analysis"

mkdir -p "$OUT_DIR"

# Chargement de l'environnement
module load conda/4.12.0
source ~/.bashrc
conda activate bioinformatic

echo "Début de la fusion pour la vigne (sed6) à $(date)"

# Trouver automatiquement les deux fichiers BAM triés (merged et unmerged)
# Adapte les noms si tes fichiers ne s'appellent pas exactement comme ça :
BAM_UNMERGED=$(ls ${BASE_DIR}/*unmerged*.sorted.bam)
BAM_MERGED=$(ls ${BASE_DIR}/*merged*.sorted.bam | grep -v "unmerged")

echo "Fichier Unmerged détecté : $BAM_UNMERGED"
echo "Fichier Merged détecté : $BAM_MERGED"

# ======================================================================
# ÉTAPE 1 : Concaténation/Fusion des fichiers BAM
# ======================================================================
echo "Fusion des fichiers avec samtools merge..."
samtools merge -f "${OUT_DIR}/sed6_Vitis_vinifera_combined.bam" "$BAM_UNMERGED" "$BAM_MERGED"

echo "Tri et Indexation du BAM combiné..."
samtools sort -o "${OUT_DIR}/sed6_Vitis_vinifera_combined.sorted.bam" "${OUT_DIR}/sed6_Vitis_vinifera_combined.bam"
samtools index "${OUT_DIR}/sed6_Vitis_vinifera_combined.sorted.bam"

# Nettoyage du fichier de fusion temporaire non trié
rm -f "${OUT_DIR}/sed6_Vitis_vinifera_combined.bam"

# ======================================================================
# ÉTAPE 2 : Lancement de mapDamage sur le fichier combiné
# ======================================================================
echo "Lancement de mapDamage sur le BAM combiné..."
mapDamage -i "${OUT_DIR}/sed6_Vitis_vinifera_combined.sorted.bam" \
  -r "$REF_FASTA" \
  --folder "${OUT_DIR}/mapDamage_combined_results" \
  --no-stats

echo "Fin des analyses avec succès à $(date)"
