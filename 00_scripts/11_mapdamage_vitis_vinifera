#!/bin/bash
#SBATCH --job-name=vigne_combined
#SBATCH --ntasks=1
#SBATCH -p smp
#SBATCH --mem=50G
#SBATCH --mail-user=alexa.martin@inrae.fr
#SBATCH --mail-type=ALL
#SBATCH --error="/home/amartin3/CapoSagro_Alexa/00_scripts/vigne_combined.err"
#SBATCH --output="/home/amartin3/CapoSagro_Alexa/00_scripts/vigne_combined.out"

# Chemins d'entrée exacts vers les dossiers mapDamage actuels
DIR_MERGED="/home/amartin3/12_mapdamage/sed6/Vitis_vinifera/clean_sed6_concat_dedup_merged_Vitis_vinifera_mapDamage_merged"
DIR_UNMERGED="/home/amartin3/12_mapdamage/sed6/Vitis_vinifera/clean_sed6_concat_dedup_unmerged_Vitis_vinifera_mapDamage_unmerged"

REF_FASTA="/home/amartin3/genomes/Vitis_vinifera.fna"

# Définition du NOUVEAU dossier de sortie demandé
OUT_DIR="/home/amartin3/12_mapdamage_vitis_vinifera"

# Création du nouveau dossier de sortie s'il n'existe pas
mkdir -p "$OUT_DIR"

# Chargement de l'environnement
module load conda/4.12.0
source ~/.bashrc
conda activate bioinformatic

echo "Début du traitement de la vigne (sed6) à $(date)"

# Récupération automatique des fichiers BAM triés dans tes dossiers cibles
BAM_MERGED=$(ls ${DIR_MERGED}/*.sorted.bam)
BAM_UNMERGED=$(ls ${DIR_UNMERGED}/*.sorted.bam)

echo "Fichier Merged trouvé : $BAM_MERGED"
echo "Fichier Unmerged trouvé : $BAM_UNMERGED"


# ======================================================================
# ÉTAPE 1 : Concaténation des fichiers via format SAM et CAT
# ======================================================================
echo "Conversion des BAMs en SAM texte dans le nouveau dossier..."
samtools view -h "$BAM_UNMERGED" > "${OUT_DIR}/unmerged.sam"
# On enlève l'en-tête (-H) pour le second fichier pour éviter de la doubler
samtools view "$BAM_MERGED" > "${OUT_DIR}/merged_no_header.sam"

echo "Concaténation des fichiers SAM avec cat..."
cat "${OUT_DIR}/unmerged.sam" "${OUT_DIR}/merged_no_header.sam" > "${OUT_DIR}/sed6_Vitis_vinifera_combined.sam"

echo "Conversion du SAM combiné en BAM trié..."
samtools sort -o "${OUT_DIR}/sed6_Vitis_vinifera_combined.sorted.bam" "${OUT_DIR}/sed6_Vitis_vinifera_combined.sam"
samtools index "${OUT_DIR}/sed6_Vitis_vinifera_combined.sorted.bam"

# Nettoyage immédiat des fichiers SAM temporaires devenus inutiles
rm -f "${OUT_DIR}/unmerged.sam" "${OUT_DIR}/merged_no_header.sam" "${OUT_DIR}/sed6_Vitis_vinifera_combined.sam"


# ======================================================================
# ÉTAPE 2 : Lancement de mapDamage dans le nouveau dossier
# ======================================================================
echo "Lancement de mapDamage sur le BAM combiné..."
mapDamage -i "${OUT_DIR}/sed6_Vitis_vinifera_combined.sorted.bam" \
  -r "$REF_FASTA" \
  --folder "${OUT_DIR}/mapDamage_combined_results" \
  --no-stats

echo "Fin du script avec succès à $(date)"
